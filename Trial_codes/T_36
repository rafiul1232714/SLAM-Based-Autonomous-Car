    print(f"\n  Test 2 v6 — Auto Steering Sign Detection")
    print(f"  PWM={args.pwm}%  KP={args.kp}")
    print(f"  Will auto-detect correct steering direction at start.\n")

    Test2LinearMotion(pwm=args.pwm, kp=args.kp, port=args.port).run()
