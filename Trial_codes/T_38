if __name__ == "__main__":
    ap = argparse.ArgumentParser()
    ap.add_argument("--pwm", type=int,   default=PWM_BASE, help="Base PWM 0-100")
    ap.add_argument("--kp",  type=float, default=YAW_KP,   help="Yaw correction gain")
    ap.add_argument("--port",type=str,   default=None,     help="/dev/ttyUSBx")
    a = ap.parse_args()
    StraightDriver(pwm=a.pwm, kp=a.kp, port=a.port).run()
