"""
Phase 2 Controlled Motion Test — EKF Navigation System
=======================================================
Motor Controller: L298N
  IN1 → Pin 11 (GPIO 17)   IN2 → Pin 13 (GPIO 27)   Motor A direction
  IN3 → Pin 15 (GPIO 22)   IN4 → Pin 16 (GPIO 23)   Motor B direction
  ENA → Pin 12 (GPIO 18)   ENB → Pin 35 (GPIO 19)   PWM speed

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
WHAT THIS TEST DOES  (NOT a full 360 spin)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  WARMUP  Car sits still 3s — EKF calibrates, compass locks heading
  T1      Car drives FORWARD ~0.3m then stops
  T2      Car drives BACKWARD ~0.3m back to start
  T3      Car SPINS LEFT  90 degrees in place (quarter turn only)
  T4      Car SPINS RIGHT 90 degrees in place (back to original heading)

  Total floor space needed: about 0.6m straight line.
  Turns are in-place, no extra width needed.

COORDINATE FRAME
  +X = forward    +Y = left    yaw increases = turning left

Run:     python3 phase2_motion_test.py
Install: pip3 install smbus2 numpy RPi.GPIO
"""

import numpy as np
import smbus2
import time
import math
import logging
from collections import deque

try:
    import RPi.GPIO as GPIO
    GPIO_AVAILABLE = True
except ImportError:
    GPIO_AVAILABLE = False
    print("WARNING: RPi.GPIO not found -- motor will not move (sensor-only mode)")

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
log = logging.getLogger("PHASE2")

# ─────────────────────────────────────────────────────
# TUNING — adjust these if tests fail
# ─────────────────────────────────────────────────────
DRIVE_SPEED  = 65   # % PWM forward/reverse
TURN_SPEED   = 80   # % PWM turning

# At 65% your car moves ~0.064 m/s
# Formula: DRIVE_TIME_S = TARGET_M / 0.064
TARGET_M     = 0.3   # metres to drive forward
DRIVE_TIME_S = 5.0   # seconds for T1 and T2

# Turn time ceiling — auto-stop exits early once 90 degrees detected
# At 80% your car turns ~8 deg/s so 90 deg needs ~11s. 15s is safe.
TURN_TIME_S  = 15.0

# ─────────────────────────────────────────────────────
# Pin Map (BOARD numbering)
# ─────────────────────────────────────────────────────
PIN_IN1 = 11;  PIN_IN2 = 13
PIN_IN3 = 15;  PIN_IN4 = 16
PIN_ENA = 12;  PIN_ENB = 35

# ─────────────────────────────────────────────────────
# I2C Addresses and Registers
# ─────────────────────────────────────────────────────
MPU6050_ADDR  = 0x68
HMC5883L_ADDR = 0x1E
PWR_MGMT_1    = 0x6B
ACCEL_XOUT_H  = 0x3B
GYRO_XOUT_H   = 0x43
ACCEL_CONFIG  = 0x1C
GYRO_CONFIG   = 0x1B
INT_PIN_CFG   = 0x37
HMC_CONFIG_A  = 0x00
HMC_CONFIG_B  = 0x01
HMC_MODE      = 0x02
HMC_DATA_X_H  = 0x03


# ─────────────────────────────────────────────────────
# Motor Controller
# ─────────────────────────────────────────────────────
class MotorController:
    def __init__(self):
        if not GPIO_AVAILABLE:
            log.warning("GPIO unavailable -- running in sensor-only mode")
            self._pwm_a = self._pwm_b = None
            return
        GPIO.setmode(GPIO.BOARD)
        GPIO.setwarnings(False)
        for pin in [PIN_IN1, PIN_IN2, PIN_IN3, PIN_IN4, PIN_ENA, PIN_ENB]:
            GPIO.setup(pin, GPIO.OUT)
            GPIO.output(pin, GPIO.LOW)
        self._pwm_a = GPIO.PWM(PIN_ENA, 1000)
        self._pwm_b = GPIO.PWM(PIN_ENB, 1000)
        self._pwm_a.start(0)
        self._pwm_b.start(0)
        log.info("Motor controller ready.")

    def _set_dir(self, in1, in2, in3, in4):
        if not GPIO_AVAILABLE: return
        GPIO.output(PIN_IN1, in1); GPIO.output(PIN_IN2, in2)
        GPIO.output(PIN_IN3, in3); GPIO.output(PIN_IN4, in4)

    def _set_speed(self, a, b):
        if not GPIO_AVAILABLE: return
        self._pwm_a.ChangeDutyCycle(a)
        self._pwm_b.ChangeDutyCycle(b)

    def forward(self):
        self._set_dir(GPIO.LOW, GPIO.HIGH, GPIO.LOW, GPIO.HIGH)
        self._set_speed(DRIVE_SPEED, DRIVE_SPEED)

    def reverse(self):
        self._set_dir(GPIO.HIGH, GPIO.LOW, GPIO.HIGH, GPIO.LOW)
        self._set_speed(DRIVE_SPEED, DRIVE_SPEED)

    def turn_left(self):
        self._set_dir(GPIO.LOW, GPIO.HIGH, GPIO.HIGH, GPIO.LOW)
        self._set_speed(TURN_SPEED, TURN_SPEED)

    def turn_right(self):
        self._set_dir(GPIO.HIGH, GPIO.LOW, GPIO.LOW, GPIO.HIGH)
        self._set_speed(TURN_SPEED, TURN_SPEED)

    def stop(self):
        self._set_speed(0, 0)
        self._set_dir(GPIO.LOW, GPIO.LOW, GPIO.LOW, GPIO.LOW)

    def cleanup(self):
        self.stop()
        if GPIO_AVAILABLE:
            if self._pwm_a: self._pwm_a.stop()
            if self._pwm_b: self._pwm_b.stop()
            GPIO.cleanup()


# ─────────────────────────────────────────────────────
# GY-87 IMU Driver
# ─────────────────────────────────────────────────────
class GY87:
    def __init__(self, bus_num=1):
        self.bus = smbus2.SMBus(bus_num)
        self._init_mpu6050()
        self._init_hmc5883l()
        self.gyro_bias  = np.zeros(3)
        self.accel_bias = np.zeros(3)
        self.roll = self.pitch = 0.0
        self.COMP_ALPHA        = 0.98
        self.IGNORE_ROLL_PITCH = True
        self.MAG_LPF           = 0.03
        self.mag_filtered      = None
        self.calibrate(samples=500)

    def _init_mpu6050(self):
        self.bus.write_byte_data(MPU6050_ADDR, PWR_MGMT_1,   0x00); time.sleep(0.1)
        self.bus.write_byte_data(MPU6050_ADDR, ACCEL_CONFIG, 0x00)
        self.bus.write_byte_data(MPU6050_ADDR, GYRO_CONFIG,  0x00)
        self.bus.write_byte_data(MPU6050_ADDR, INT_PIN_CFG,  0x02); time.sleep(0.05)

    def _init_hmc5883l(self):
        try:
            self.bus.write_byte_data(HMC5883L_ADDR, HMC_CONFIG_A, 0x70)
            self.bus.write_byte_data(HMC5883L_ADDR, HMC_CONFIG_B, 0x20)
            self.bus.write_byte_data(HMC5883L_ADDR, HMC_MODE,     0x00)
            self.mag_available = True
            log.info("HMC5883L found.")
        except Exception as e:
            log.warning(f"HMC5883L not found: {e}")
            self.mag_available = False

    def _read_word(self, addr, reg):
        hi = self.bus.read_byte_data(addr, reg)
        lo = self.bus.read_byte_data(addr, reg + 1)
        v  = (hi << 8) | lo
        return v - 65536 if v > 32767 else v

    def read_accel_raw(self):
        ax = self._read_word(MPU6050_ADDR, ACCEL_XOUT_H)
        ay = self._read_word(MPU6050_ADDR, ACCEL_XOUT_H + 2)
        az = self._read_word(MPU6050_ADDR, ACCEL_XOUT_H + 4)
        return np.array([ax, ay, az]) / 16384.0 * 9.80665

    def read_gyro_raw(self):
        gx = self._read_word(MPU6050_ADDR, GYRO_XOUT_H)
        gy = self._read_word(MPU6050_ADDR, GYRO_XOUT_H + 2)
        gz = self._read_word(MPU6050_ADDR, GYRO_XOUT_H + 4)
        return np.array([gx, gy, gz]) / 131.0 * (math.pi / 180.0)

    def read_mag_raw(self):
        if not self.mag_available: return None
        try:
            mx = self._read_word(HMC5883L_ADDR, HMC_DATA_X_H)
            mz = self._read_word(HMC5883L_ADDR, HMC_DATA_X_H + 2)
            my = self._read_word(HMC5883L_ADDR, HMC_DATA_X_H + 4)
            return np.array([float(mx), float(my), float(mz)])
        except:
            return None

    def calibrate(self, samples=500):
        log.info(f"Calibrating ({samples} samples) -- keep STILL...")
        g_sum = np.zeros(3); a_sum = np.zeros(3)
        for i in range(samples):
            g_sum += self.read_gyro_raw()
            a_sum += self.read_accel_raw()
            time.sleep(0.005)
            if i % 100 == 0: log.info(f"  {i}/{samples}...")
        self.gyro_bias  = g_sum / samples
        self.accel_bias = a_sum / samples
        self.accel_bias[2] -= 9.80665
        log.info(f"Gyro bias  (rad/s): {np.round(self.gyro_bias, 5)}")
        log.info(f"Accel bias (m/s2):  {np.round(self.accel_bias, 5)}")

    def update_bias_adaptive(self, accel, gyro, alpha=0.005):
        self.gyro_bias[0]  += alpha * gyro[0]
        self.gyro_bias[1]  += alpha * gyro[1]
        self.gyro_bias[2]  += alpha * 3.0 * gyro[2]
        self.accel_bias[0] += alpha * accel[0]
        self.accel_bias[1] += alpha * accel[1]

    def update_tilt(self, accel_cal, gyro, dt):
        norm = np.linalg.norm(accel_cal)
        if norm < 1.0: return
        ax, ay, az  = accel_cal / norm
        roll_a  =  math.atan2(ay, az)
        pitch_a = -math.asin(max(-1.0, min(1.0, ax)))
        self.roll  = self.COMP_ALPHA*(self.roll  + gyro[0]*dt) + (1-self.COMP_ALPHA)*roll_a
        self.pitch = self.COMP_ALPHA*(self.pitch + gyro[1]*dt) + (1-self.COMP_ALPHA)*pitch_a

    def remove_gravity(self, accel_cal):
        if self.IGNORE_ROLL_PITCH:
            return np.array([accel_cal[0], accel_cal[1], 0.0])
        cr, sr = math.cos(self.roll), math.sin(self.roll)
        cp, sp = math.cos(self.pitch), math.sin(self.pitch)
        grav = np.array([sp*9.80665, -sr*cp*9.80665, -cr*cp*9.80665])
        return accel_cal - grav

    def get_heading(self):
        mag = self.read_mag_raw()
        if mag is None: return None
        cr, sr = math.cos(self.roll), math.sin(self.roll)
        cp, sp = math.cos(self.pitch), math.sin(self.pitch)
        mx = mag[0]*cp + mag[2]*sp
        my = mag[0]*sr*sp + mag[1]*cr - mag[2]*sr*cp
        h_raw = math.atan2(my, mx)
        if self.mag_filtered is None:
            self.mag_filtered = h_raw
            return h_raw
        diff = math.atan2(math.sin(h_raw - self.mag_filtered),
                          math.cos(h_raw - self.mag_filtered))
        self.mag_filtered = math.atan2(
            math.sin(self.mag_filtered + self.MAG_LPF * diff),
            math.cos(self.mag_filtered + self.MAG_LPF * diff))
        return self.mag_filtered


# ─────────────────────────────────────────────────────
# EKF   state = [x, y, vx, vy, yaw]
# ─────────────────────────────────────────────────────
class EKF:
    def __init__(self):
        self.X = np.zeros(5)
        self.P = np.diag([1.0, 1.0, 0.5, 0.5, 0.1])
        self.Q_moving = np.diag([0.01, 0.01, 0.10, 0.10, 0.001])
        self.Q_static = np.diag([0.001, 0.001, 0.001, 0.001, 0.0001])
        self.Q             = self.Q_moving.copy()
        self.R_mag_moving  = np.array([[9999.0]])
        self.R_mag_static  = np.array([[0.02]])
        self.R_mag         = self.R_mag_moving.copy()
        self.R_zupt        = np.diag([0.001, 0.001])

    def predict(self, accel, gyro_z, dt, freeze_yaw=False):
        x, y, vx, vy, yaw = self.X
        cy = math.cos(yaw); sy = math.sin(yaw)
        ax_w = cy*accel[0] - sy*accel[1]
        ay_w = sy*accel[0] + cy*accel[1]
        self.X[0] = x  + vx*dt + 0.5*ax_w*dt**2
        self.X[1] = y  + vy*dt + 0.5*ay_w*dt**2
        self.X[2] = vx + ax_w*dt
        self.X[3] = vy + ay_w*dt
        if not freeze_yaw:
            self.X[4] = math.atan2(math.sin(yaw + gyro_z*dt),
                                   math.cos(yaw + gyro_z*dt))
        dax = -sy*accel[0] - cy*accel[1]
        day =  cy*accel[0] - sy*accel[1]
        F = np.eye(5); F[0,2]=dt; F[1,3]=dt
        if not freeze_yaw:
            F[0,4]=0.5*dax*dt**2; F[1,4]=0.5*day*dt**2
            F[2,4]=dax*dt;        F[3,4]=day*dt
        self.P = F @ self.P @ F.T + self.Q

    def update_mag(self, heading):
        if heading is None: return
        H    = np.array([[0,0,0,0,1]])
        yres = np.array([math.atan2(math.sin(heading - self.X[4]),
                                    math.cos(heading - self.X[4]))])
        S = H @ self.P @ H.T + self.R_mag
        K = self.P @ H.T @ np.linalg.inv(S)
        self.X += (K @ yres).flatten()
        self.X[4] = math.atan2(math.sin(self.X[4]), math.cos(self.X[4]))
        self.P = (np.eye(5) - K @ H) @ self.P

    def update_zupt(self):
        H = np.array([[0,0,1,0,0],[0,0,0,1,0]])
        self._update(H, np.zeros(2), self.R_zupt)

    def update_yaw_rate_zupt(self):
        H = np.array([[0,0,0,0,1]]); R = np.array([[0.005]])
        S = H @ self.P @ H.T + R; K = self.P @ H.T @ np.linalg.inv(S)
        if self.P[4,4] > 0.001:
            self.X += (K @ np.array([0.0])).flatten()
            self.X[4] = math.atan2(math.sin(self.X[4]), math.cos(self.X[4]))
            self.P = (np.eye(5) - K @ H) @ self.P

    def _update(self, H, z, R):
        yres = z - H @ self.X
        S = H @ self.P @ H.T + R
        K = self.P @ H.T @ np.linalg.inv(S)
        self.X += (K @ yres).flatten()
        self.X[4] = math.atan2(math.sin(self.X[4]), math.cos(self.X[4]))
        IKH = np.eye(5) - K @ H
        self.P = IKH @ self.P @ IKH.T + K @ R @ K.T

    def set_stationary_mode(self, s):
        self.Q     = self.Q_static     if s else self.Q_moving
        self.R_mag = self.R_mag_static if s else self.R_mag_moving

    def reset_position(self):
        self.X[0]=self.X[1]=self.X[2]=self.X[3]=0.0
        self.P[0,0]=self.P[1,1]=1.0; self.P[2,2]=self.P[3,3]=0.5

    @property
    def state(self):
        return {"x": self.X[0], "y": self.X[1],
                "vx": self.X[2], "vy": self.X[3],
                "yaw": math.degrees(self.X[4]),
                "speed": math.hypot(self.X[2], self.X[3])}


# ─────────────────────────────────────────────────────
# Stationary Detector
# ─────────────────────────────────────────────────────
class StationaryDetector:
    def __init__(self, window=20, accel_thresh=0.15, gyro_thresh=0.05):
        self.accel_buf    = deque(maxlen=window)
        self.gyro_buf     = deque(maxlen=window)
        self.accel_thresh = accel_thresh
        self.gyro_thresh  = gyro_thresh

    def update(self, accel, gyro):
        self.accel_buf.append(accel[:2].copy())
        self.gyro_buf.append(gyro[:3].copy())
        if len(self.accel_buf) < self.accel_buf.maxlen: return True
        av = np.max(np.var(np.array(self.accel_buf), axis=0))
        gv = np.max(np.var(np.array(self.gyro_buf),  axis=0))
        return av < self.accel_thresh and gv < self.gyro_thresh


# ─────────────────────────────────────────────────────
# Nav Loop
# ─────────────────────────────────────────────────────
class NavLoop:
    VELOCITY_FLOOR = 0.001

    def __init__(self, imu, ekf, detector):
        self.imu        = imu
        self.ekf        = ekf
        self.detector   = detector
        self.gyro_z_raw = 0.0

    def tick(self, dt, drive_mode='idle'):
        ar = self.imu.read_accel_raw()
        gr = self.imu.read_gyro_raw()
        ac = ar - self.imu.accel_bias
        gc = gr - self.imu.gyro_bias
        self.gyro_z_raw = gc[2]
        self.imu.update_tilt(ac, gc, dt)
        still = self.detector.update(ac, gc)
        self.ekf.set_stationary_mode(still)

        if drive_mode == 'idle':
            al = self.imu.remove_gravity(ac)
            if still: self.imu.update_bias_adaptive(ac, gc, alpha=0.005)
            self.ekf.predict(al[:2], gc[2], dt, freeze_yaw=False)
            if still:
                self.ekf.update_zupt()
                self.ekf.update_yaw_rate_zupt()
                if abs(self.ekf.X[2]) < self.VELOCITY_FLOOR: self.ekf.X[2] = 0.0
                if abs(self.ekf.X[3]) < self.VELOCITY_FLOOR: self.ekf.X[3] = 0.0
            self.ekf.update_mag(self.imu.get_heading())

        elif drive_mode == 'straight':
            # Accel zeroed: motor vibration corrupts it completely.
            # Velocity is fixed from kickstart. Pure dead reckoning: x += vx*dt
            # Yaw frozen: gyro Z corrupted by vibration during straight drive.
            self.ekf.predict(np.zeros(2), 0.0, dt, freeze_yaw=True)

        elif drive_mode == 'turn':
            # Accel zeroed: car pivots, no translation.
            # Gyro Z only updates yaw. Position stays fixed.
            self.ekf.predict(np.zeros(2), gc[2], dt, freeze_yaw=False)

        return still


# ─────────────────────────────────────────────────────
# Phase 2 Test Runner
# ─────────────────────────────────────────────────────
class Phase2Test:
    PASS = "PASS"
    FAIL = "FAIL"

    STRAIGHT_ERROR_M = 0.15
    RETURN_ERROR_M   = 0.15
    SIDE_DRIFT_M     = 0.12
    TURN_ERROR_DEG   = 15.0

    def __init__(self):
        self.imu      = GY87(bus_num=1)
        self.ekf      = EKF()
        self.detector = StationaryDetector()
        self.motor    = MotorController()
        self.nav      = NavLoop(self.imu, self.ekf, self.detector)
        self.results  = []
        self.logfile  = open("phase2_results.csv", "w")
        self.logfile.write("t,test,status,x,y,vx,vy,yaw\n")
        self._last_drive_yaw   = 0.0
        self._actual_t3_change = 90.0

    # ── EKF loop ─────────────────────────────────────────────────────────
    def _run_loop(self, duration_s, label, drive_mode='idle', print_hz=2):
        IMU_HZ = 100; dt = 1.0/IMU_HZ
        print_every = IMU_HZ // print_hz
        counter = 0; t_start = t_prev = time.time()
        while True:
            t_now = time.time(); elapsed = t_now - t_start
            if elapsed >= duration_s: break
            real_dt = min(t_now - t_prev, 0.05); t_prev = t_now
            still = self.nav.tick(real_dt, drive_mode=drive_mode)
            s = self.ekf.state
            self.logfile.write(
                f"{elapsed:.3f},{label},{'STILL' if still else 'MOVING'},"
                f"{s['x']:.4f},{s['y']:.4f},{s['vx']:.4f},{s['vy']:.4f},{s['yaw']:.2f}\n")
            counter += 1
            if counter >= print_every:
                counter = 0
                print(f"  t={elapsed:6.2f}s | {'STILL ' if still else 'MOVING'} | "
                      f"x={s['x']:8.4f}m  y={s['y']:8.4f}m  "
                      f"vx={s['vx']:7.4f}m/s  vy={s['vy']:7.4f}m/s  yaw={s['yaw']:7.2f}deg")
            sl = dt - (time.time() - t_now)
            if sl > 0: time.sleep(sl)
        return self.ekf.state

    # ── Capture velocity in first 1s after motor starts ──────────────────
    def _kickstart_velocity(self, direction, drive_yaw_rad):
        """
        Run with accel integration for 1 second so motor reaches speed.
        Then lock velocity direction along drive_yaw_rad.
        Uses speed floor of 0.02 m/s so dead reckoning always moves.
        """
        IMU_HZ = 100; dt = 1.0/IMU_HZ
        t_start = t_prev = time.time()
        vx_sum = vy_sum = 0.0; samples = 0
        while time.time() - t_start < 1.0:
            t_now = time.time(); real_dt = min(t_now - t_prev, 0.05); t_prev = t_now
            ar = self.nav.imu.read_accel_raw(); gr = self.nav.imu.read_gyro_raw()
            ac = ar - self.nav.imu.accel_bias;  gc = gr - self.nav.imu.gyro_bias
            self.nav.imu.update_tilt(ac, gc, real_dt)
            al = self.nav.imu.remove_gravity(ac)
            self.ekf.predict(al[:2], gc[2], real_dt, freeze_yaw=True)
            vx_sum += self.ekf.X[2]; vy_sum += self.ekf.X[3]; samples += 1
            sl = dt - (time.time() - t_now)
            if sl > 0: time.sleep(sl)
        speed = math.hypot(vx_sum/max(samples, 1), vy_sum/max(samples, 1))
        speed = max(speed, 0.02)   # floor: always move at least 0.02 m/s
        self.ekf.X[2] = direction * speed * math.cos(drive_yaw_rad)
        self.ekf.X[3] = direction * speed * math.sin(drive_yaw_rad)
        log.info(f"  Kickstart: speed={speed:.4f}m/s  dir={direction:+d}  "
                 f"yaw={math.degrees(drive_yaw_rad):.1f}deg")

    # ── Turn loop with auto-stop ──────────────────────────────────────────
    def _run_loop_turn(self, duration_s, label, target_yaw_change, print_hz=2):
        IMU_HZ = 100; dt = 1.0/IMU_HZ
        print_every = IMU_HZ // print_hz
        counter = 0; t_start = t_prev = time.time()
        yaw_start = self.ekf.state["yaw"]
        while True:
            t_now = time.time(); elapsed = t_now - t_start
            if elapsed >= duration_s: break
            real_dt = min(t_now - t_prev, 0.05); t_prev = t_now
            self.nav.tick(real_dt, drive_mode='turn')
            s = self.ekf.state
            change = (s["yaw"] - yaw_start + 180) % 360 - 180
            if abs(change) >= abs(target_yaw_change) * 0.90:
                log.info(f"  Auto-stop: yaw changed {change:+.1f}deg at t={elapsed:.1f}s")
                break
            self.logfile.write(
                f"{elapsed:.3f},{label},TURNING,"
                f"{s['x']:.4f},{s['y']:.4f},{s['vx']:.4f},{s['vy']:.4f},{s['yaw']:.2f}\n")
            counter += 1
            if counter >= print_every:
                counter = 0
                gz = math.degrees(self.nav.gyro_z_raw)
                print(f"  t={elapsed:6.2f}s | TURNING | yaw={s['yaw']:7.2f}deg  "
                      f"gyro_z={gz:7.2f}deg/s  x={s['x']:7.4f}m  y={s['y']:7.4f}m")
            sl = dt - (time.time() - t_now)
            if sl > 0: time.sleep(sl)
        return self.ekf.state

    # ── Stop and settle ───────────────────────────────────────────────────
    def _wait_stop(self):
        self.motor.stop()
        log.info("  Waiting for car to stop...")
        self._run_loop(2.0, "STOPPING", drive_mode='idle')

    # ── T1: Forward ───────────────────────────────────────────────────────
    def test_forward(self):
        print("\n" + "-"*65)
        print(f"T1 -- FORWARD {TARGET_M}m  ({DRIVE_TIME_S}s at {DRIVE_SPEED}%)")
        print(f"  Expected: x grows to ~+{TARGET_M}m,  y stays near 0")
        print("-"*65)
        self.ekf.reset_position()
        # Save heading BEFORE motors start.
        # After T1 stops, mag correction will shift EKF yaw.
        # T2 must use this saved heading, not the shifted one.
        self._last_drive_yaw = self.ekf.X[4]
        log.info(f"  Drive heading locked: {math.degrees(self._last_drive_yaw):.1f}deg")
        self.motor.forward()
        self._kickstart_velocity(direction=+1, drive_yaw_rad=self._last_drive_yaw)
        state = self._run_loop(DRIVE_TIME_S, "FORWARD", drive_mode='straight')
        self._wait_stop()
        x  = state["x"]
        yd = abs(state["y"])
        self.results.append(("T1a Forward x reached",
                              f"{x:.4f}m",
                              f"target {TARGET_M}+-{self.STRAIGHT_ERROR_M}m",
                              self.PASS if abs(x - TARGET_M) < self.STRAIGHT_ERROR_M else self.FAIL))
        self.results.append(("T1b Forward y drift",
                              f"{yd:.4f}m",
                              f"limit <{self.SIDE_DRIFT_M}m",
                              self.PASS if yd < self.SIDE_DRIFT_M else self.FAIL))

    # ── T2: Reverse ───────────────────────────────────────────────────────
    def test_reverse(self):
        print("\n" + "-"*65)
        print(f"T2 -- REVERSE  ({DRIVE_TIME_S}s at {DRIVE_SPEED}%)")
        print("  Expected: x returns to ~0.0m")
        print("-"*65)
        # Use heading saved in T1, NOT current EKF yaw
        self.motor.reverse()
        self._kickstart_velocity(direction=-1, drive_yaw_rad=self._last_drive_yaw)
        state = self._run_loop(DRIVE_TIME_S, "REVERSE", drive_mode='straight')
        self._wait_stop()
        x = state["x"]
        self.results.append(("T2 Return-to-origin x",
                              f"{x:.4f}m",
                              f"limit +-{self.RETURN_ERROR_M}m",
                              self.PASS if abs(x) < self.RETURN_ERROR_M else self.FAIL))

    # ── T3: Spin left 90 degrees ──────────────────────────────────────────
    def test_turn_left(self):
        print("\n" + "-"*65)
        print(f"T3 -- SPIN LEFT 90deg  (max {TURN_TIME_S}s at {TURN_SPEED}%, auto-stops)")
        print("  Expected: yaw +90deg,  x/y stay near 0")
        print("-"*65)
        self.ekf.reset_position()
        yaw_before = self.ekf.state["yaw"]
        self.motor.turn_left()
        state = self._run_loop_turn(TURN_TIME_S, "TURN_LEFT", target_yaw_change=+90)
        self._wait_stop()
        change = (state["yaw"] - yaw_before + 180) % 360 - 180
        self._actual_t3_change = change   # T4 will undo exactly this
        ok = abs(change - 90.0) < self.TURN_ERROR_DEG
        self.results.append(("T3 Left turn yaw change",
                              f"{change:+.2f}deg",
                              f"target +90+-{self.TURN_ERROR_DEG}deg",
                              self.PASS if ok else self.FAIL))
        return yaw_before

    # ── T4: Spin right to undo T3 ─────────────────────────────────────────
    def test_turn_right(self, yaw_target):
        print("\n" + "-"*65)
        print(f"T4 -- SPIN RIGHT  (max {TURN_TIME_S}s at {TURN_SPEED}%, auto-stops)")
        print(f"  Expected: yaw returns to ~{yaw_target:.1f}deg")
        print("-"*65)
        # KEY FIX: undo exactly what T3 achieved.
        # If T3 turned 58deg, T4 turns back 58deg — NOT a hardcoded 90deg.
        undo = -self._actual_t3_change
        log.info(f"  T3 turned {self._actual_t3_change:+.1f}deg -> T4 undoing {undo:+.1f}deg")
        self.motor.turn_right()
        state = self._run_loop_turn(TURN_TIME_S, "TURN_RIGHT", target_yaw_change=undo)
        self._wait_stop()
        yaw_after = state["yaw"]
        err = abs(yaw_after - yaw_target)
        err = min(err, 360 - err)
        self.results.append(("T4 Right turn yaw return",
                              f"{yaw_after:.2f}deg",
                              f"target {yaw_target:.1f}+-{self.TURN_ERROR_DEG}deg",
                              self.PASS if err < self.TURN_ERROR_DEG else self.FAIL))

    # ── Main ──────────────────────────────────────────────────────────────
    def run(self):
        print("\n" + "="*65)
        print("  PHASE 2 -- CONTROLLED MOTION TEST")
        print(f"  Drive speed: {DRIVE_SPEED}%   Turn speed: {TURN_SPEED}%")
        print(f"  Target: {TARGET_M}m forward/reverse,  90deg turns")
        print("="*65)
        print("\n  Starting in 5 seconds -- place car on flat floor, facing forward")
        for i in range(5, 0, -1):
            print(f"  {i}..."); time.sleep(1)
        try:
            print("\n  [Warmup -- holding still 3s]")
            self._run_loop(3.0, "WARMUP", drive_mode='idle')
            print(f"  Initial yaw: {self.ekf.state['yaw']:.2f}deg")
            self.test_forward()
            time.sleep(1)
            self.test_reverse()
            time.sleep(1)
            yaw_before_turn = self.test_turn_left()
            time.sleep(1)
            self.test_turn_right(yaw_target=yaw_before_turn)
        except KeyboardInterrupt:
            log.info("Test interrupted.")
        finally:
            self.motor.cleanup()
            self.logfile.close()
        self._report()

    # ── Report ────────────────────────────────────────────────────────────
    def _report(self):
        print("\n" + "="*70)
        print(f"  {'TEST':<35} {'VALUE':<20} {'LIMIT':<22} RESULT")
        print("="*70)
        passed = failed = 0
        for name, value, limit, result in self.results:
            icon = "[OK]" if result == self.PASS else "[!!]"
            print(f"  {icon} {name:<33} {value:<20} {limit:<22} {result}")
            if result == self.PASS: passed += 1
            else: failed += 1
        print("="*70)
        print(f"  SUMMARY: {passed} passed, {failed} failed")
        if failed == 0:
            print("  ALL TESTS PASSED -- system ready for Phase 3")
        else:
            print("  FAILURES DETECTED -- tuning guide:")
            for name, value, limit, result in self.results:
                if result != self.FAIL: continue
                if "x reached" in name:
                    print(f"\n  [T1 FAIL] x too low -> increase DRIVE_TIME_S (now {DRIVE_TIME_S}s)")
                    print(f"           Each +1s adds ~0.064m at {DRIVE_SPEED}% speed")
                if "y drift" in name:
                    print(f"\n  [T1 FAIL] y drift -> one motor faster, or sensor tilted sideways")
                if "return" in name.lower():
                    print(f"\n  [T2 FAIL] didn't return -> DRIVE_TIME_S must be same as T1")
                if "turn" in name.lower():
                    print(f"\n  [T3/T4 FAIL] not enough turn -> increase TURN_TIME_S (now {TURN_TIME_S}s)")
                    print(f"              Auto-stop will still exit early when 90deg reached")
        print("="*70)
        print("  Log: phase2_results.csv")


if __name__ == "__main__":
    Phase2Test().run()
